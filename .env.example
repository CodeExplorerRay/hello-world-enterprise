GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override the runtime Gemini model if needed.
# GEMINI_MODEL=gemini-flash-lite-latest
# Optional: comma-separated browser origins allowed to call the API gateway directly.
# API_GATEWAY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: require an X-API-Key header for /api/* requests when set.
# API_GATEWAY_API_KEY=replace_me
# Optional: enable Cloud Run identity-token auth for gateway-to-service calls.
# GCP_SERVICE_TO_SERVICE_AUTH=false
